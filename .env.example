# ──────────────────────────────────────────────────────────
# YouTube Automation Command Center — Environment Template
# Copy to .env and fill in your keys. NEVER commit .env.
# ──────────────────────────────────────────────────────────

# YouTube Data API v3 (https://console.cloud.google.com)
YOUTUBE_API_KEY=
# OAuth for uploads (advanced, optional at MVP)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# AI providers
OPENAI_API_KEY=           # https://platform.openai.com/api-keys
ANTHROPIC_API_KEY=        # https://console.anthropic.com (optional)
ELEVENLABS_API_KEY=       # https://elevenlabs.io/docs (voiceover)

# Project management (pick one)
NOTION_API_KEY=           # https://developers.notion.com
NOTION_DB_ID=
TRELLO_API_KEY=           # https://trello.com/app-key
TRELLO_API_TOKEN=
TRELLO_BOARD_ID=

# Reddit (idea scraping — https://old.reddit.com/prefs/apps, create "script" app)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=yacc-idea-bot/0.1 by /u/YourRedditUser

# Discord webhook (alerts & digests — in Discord channel settings → Integrations → Webhooks)
DISCORD_WEBHOOK_URL=

# n8n (if running)
N8N_WEBHOOK_URL=http://localhost:5678/webhook
N8N_WEBHOOK_SECRET=change-me-to-something-random

# Mobile dashboard
DASHBOARD_JSON_URL=http://localhost:5173/dashboard.json
DASHBOARD_PASSWORD=changeme

# Python scripts
PYTHONUNBUFFERED=1
TZ=UTC
